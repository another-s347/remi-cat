# remi-cat configuration
# Copy to .env and fill in your values before running `docker compose up`.

# ── Feishu Enterprise App ──────────────────────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI-compatible LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override API base URL (e.g. for a local LLM proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: model name (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Owner pre-configuration (optional) ──────────────────────────────────────
# Set to skip the /pair flow on first boot.
# The value is the user's Feishu open_id (e.g. ou_xxxxxxxx).
# REMI_CAT_OWNER_ID=

# ── Log level (optional) ─────────────────────────────────────────────────────
# RUST_LOG=remi_cat=debug,im_feishu=debug
