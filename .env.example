# remi-cat configuration
#
# ── Setup options ────────────────────────────────────────────────────────────
#
# Option A (initial setup / simple): copy to .env and fill in your values.
#
# Option B (recommended after first boot): store credentials in the encrypted
# secret store instead of this file.  Once the daemon is running, use the
# admin UI or the /secrets Feishu command to set the keys:
#
#   /secrets set FEISHU_APP_ID     cli_xxxx
#   /secrets set FEISHU_APP_SECRET xxxx
#   /secrets set OPENAI_API_KEY    sk-xxxx
#   /secrets set OPENAI_BASE_URL   https://api.openai.com/v1
#   /secrets set OPENAI_MODEL      gpt-4o
#   /secrets set EXA_API_KEY       xxxx
#
# The daemon reads FEISHU_APP_ID and FEISHU_APP_SECRET from the encrypted
# secret store if the corresponding env vars are not set.  OPENAI_* and
# EXA_API_KEY are synced from the store into the agent process automatically.
#
# The secret store is encrypted with AES-256-GCM; the encryption key is stored
# in secrets.key (owner-readable only, mode 0600).

# ── Feishu Enterprise App ──────────────────────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI-compatible LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override API base URL (e.g. for a local LLM proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: model name (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Owner pre-configuration (optional) ──────────────────────────────────────
# Set to skip the /pair flow on first boot.
# The value is the user's Feishu open_id (e.g. ou_xxxxxxxx).
# REMI_CAT_OWNER_ID=

# ── Log level (optional) ─────────────────────────────────────────────────────
# RUST_LOG=remi_cat=debug,im_feishu=debug
