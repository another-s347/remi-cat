# remi-cat single-runtime configuration
#
# Recommended first step:
#   remi-cat setup

# Feishu Enterprise App. Required unless running with --local / --cli-im.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI-compatible LLM.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional when using `remi-cat setup`; setup writes runtime.yaml and seeds
# model profiles / agent profiles automatically.
# REMI_MODEL_PROFILE=default

# Feishu inbound transport. websocket is the default long connection mode.
# event_hook starts a local HTTP callback listener; expose this URL publicly and
# configure it in Feishu app event subscriptions.
# REMI_FEISHU_TRANSPORT=websocket
# REMI_FEISHU_HOOK_HOST=127.0.0.1
# REMI_FEISHU_HOOK_PORT=8788
# REMI_FEISHU_HOOK_PATH=/feishu/events
# REMI_FEISHU_HOOK_VERIFICATION_TOKEN=

# Data and agent profile configuration.
# REMI_DATA_DIR=.remi-cat
# REMI_AGENTS_DIR=.remi-cat/agents
# REMI_AGENT_ID=default

# Legacy fallback only when no model profile files exist.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Shell backend. Bash is registered only when this is explicitly local and the
# active agent profile allowlists `bash`.
# REMI_SHELL_MODE=local

# ACP. If REMI_ACP_BASE_URL is unset, the local stub backend is used.
# REMI_ACP_MODE=local
# REMI_ACP_CLIENT=remi
# REMI_ACP_BASE_URL=https://acp.example.com
# REMI_ACP_API_KEY=xxxx
# REMI_ACP_AGENT_NAME=default
# REMI_ACP_MODEL=gpt-5-codex

# Admin/runtime logging.
# REMI_ADMIN_HOST=127.0.0.1
# REMI_ADMIN_PORT=8787
# RUST_LOG=remi_cat=info,bot_core=info,im_feishu=info
