# Web UI dependencies are restored from web-ui/package-lock.json.
web-ui/node_modules/

# ── Multi-platform skill stores (runtime data) ────────────────────────────────
.agents/
.claude/
.hermes/
.kiro/
.windsurf/

# ── Downloaded content (runtime data) ─────────────────────────────────────────
fetch/

